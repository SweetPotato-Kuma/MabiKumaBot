# Nexon Open API key for Mabinogi. API_KEY is the shortest supported name.
API_KEY=
# MABINOGI_API_KEY=your_nexon_api_key_here

# Discord bot token. TOKEN is supported for compatibility with simple discord.js guides.
TOKEN=your_discord_bot_token_here
# DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Optional: Discord application/client ID. Only required for npm run deploy:commands.
DISCORD_CLIENT_ID=

# Optional: register commands to one guild for instant development updates.
# If empty, commands are registered globally and can take time to propagate.
DISCORD_GUILD_ID=

# Optional: seed alert channel. You can also set this in Discord with /알림채널 설정.
DISCORD_CHANNEL_ID=

# Optional seed list used only when data/items.json does not exist yet.
MABINOGI_ITEMS=튼튼한 고양이의 구슬,마나 허브

# Monitor settings.
CHECK_INTERVAL_SECONDS=10
REQUEST_TIMEOUT_SECONDS=10
ALERT_DISCOUNT_THRESHOLD=0.1
ALERT_COOLDOWN_SECONDS=3600

# Optional: deploy slash commands automatically when the bot starts.
AUTO_DEPLOY_COMMANDS=true
